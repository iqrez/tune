    btn_diag.click(run_port_diagnostics, outputs=[diag_status, diag_table])
    btn_wakeup.click(force_wakeup_action, inputs=[manual_port], outputs=[diag_status])
    btn_wake_binary.click(wake_binary_action, inputs=[manual_port], outputs=[diag_status])
    btn_reflash.click(show_reflash_wizard, outputs=[reflash_wizard])
    btn_send.click(agent_chat_handler, inputs=[msg, chatbot, profile_state], outputs=[chatbot])
    msg.submit(agent_chat_handler, inputs=[msg, chatbot, profile_state], outputs=[chatbot])
    btn_connect.click(connect_ecu_action, inputs=[conn_mode, manual_port, port_mode], outputs=[status, console_banner])
    btn_auto.click(lambda: "Perform full auto setup.", outputs=msg).then(
        agent_chat_handler, inputs=[msg, chatbot, profile_state], outputs=[chatbot]
    )

    # Table editor actions
    table_select.change(handle_table_select, inputs=[table_select, table_state], outputs=[table_state, table_status])

        inputs=[table_state],
        outputs=[table_state, table_editor_html, table_status],
    )
    btn_undo_all.click(
        undo_all_changes,
        inputs=[table_state],
        outputs=[table_state, table_editor_html, table_surface, table_status],
    )
    btn_export_msq.click(export_msq, inputs=[table_state], outputs=[export_file, table_status])
    btn_import_msq.click(

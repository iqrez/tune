        outputs=[datalog_state, datalog_chart],
    )
    scatter_x.change(
        datalog_apply_scatter,
        inputs=[scatter_x, scatter_y, datalog_state],
        outputs=[datalog_state, datalog_scatter],
    )
    scatter_y.change(
        datalog_apply_scatter,
        inputs=[scatter_x, scatter_y, datalog_state],
        outputs=[datalog_state, datalog_scatter],
    )
    btn_apply_filter.click(
